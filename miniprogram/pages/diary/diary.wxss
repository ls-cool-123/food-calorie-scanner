.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f6f6f6;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}
.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 今日总结卡片 */
.summary-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.summary-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.summary-kcal {
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
}
.summary-unit {
  font-size: 32rpx;
  color: #999;
  font-weight: normal;
}
.summary-goal {
  font-size: 26rpx;
  color: #666;
  margin-top: 12rpx;
}
.summary-gap {
  margin-left: 16rpx;
  font-weight: bold;
}
.gap-deficit {
  color: #fa8c16;
}
.gap-surplus {
  color: #e64340;
}

.ai-btn {
  margin-top: 30rpx;
  width: auto;
  min-width: 280rpx;
  height: 72rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  border: none;
}
.ai-btn::after {
  border: none;
}

/* AI 建议弹窗 */
.advice-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}
.advice-panel {
  width: 86%;
  max-height: 70vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.advice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.advice-title {
  font-size: 34rpx;
  font-weight: bold;
}
.advice-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}
.advice-body {
  padding: 30rpx;
}
.advice-scenario {
  display: inline-block;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  color: #fff;
}
.scenario-deficit {
  background: #fa8c16;
}
.scenario-surplus {
  background: #e64340;
}
.advice-summary {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 24rpx;
}
.advice-list-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.advice-item {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  padding-left: 8rpx;
}
.advice-error {
  font-size: 28rpx;
  color: #999;
}
.advice-loading {
  text-align: center;
  padding: 60rpx 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* 今日饮食 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}
.food-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.food-item:last-child {
  border-bottom: none;
}
.food-info {
  flex: 1;
}
.food-name {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}
.food-detail {
  font-size: 24rpx;
  color: #999;
}
.food-kcal-row {
  text-align: right;
}
.food-kcal {
  font-size: 30rpx;
  font-weight: bold;
  color: #e64340;
  display: block;
}
.food-delete {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.today-empty {
  text-align: center;
  padding: 80rpx 40rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}
.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* 历史记录 */
.history-section {
  margin-top: 40rpx;
}
.history-group {
  margin-bottom: 30rpx;
}
.history-date {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx 16rpx;
}
.history-date text:first-child {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
.history-total {
  font-size: 26rpx;
  color: #e64340;
  font-weight: bold;
}
