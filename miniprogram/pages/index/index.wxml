<!-- 主容器 -->
<view class="container">
  <!-- 拍照按钮 -->
  <button class="camera-btn" bindtap="chooseImage">拍食物 查热量</button>

  <!-- 图片展示区 -->
  <view class="img-box" wx:if="{{imgSrc}}">
    <image src="{{imgSrc}}" mode="aspectFit" class="food-img"></image>
  </view>

  <!-- 识别结果展示区 -->
  <view class="result-card" wx:if="{{result}}">
    <view class="result-title">识别结果</view>
    <view class="result-item">
      <text>食物名称：</text>
      <text class="highlight">{{result.name}}</text>
      <text wx:if="{{result._confidence}}" class="confidence-badge">AI识别</text>
      <text wx:else class="confidence-badge manual-badge">手动选择</text>
    </view>
    <view class="result-item">
      <text>热量：</text>
      <text class="calorie">{{result.calorie}}</text>
      <text> kcal/100g</text>
    </view>
    <view class="calc-box">
      <text>食用克数：</text>
      <input
        type="number"
        placeholder="请输入你吃了多少克"
        bindinput="calcTotalCalorie"
        class="weight-input"
      ></input>
    </view>
    <view class="total-result" wx:if="{{totalCalorie}}">
      本次摄入总热量：<text class="highlight">{{totalCalorie}} kcal</text>
    </view>
    <view class="manual-select-entry" bindtap="showAllFoodsList">
      <text>不是这个食物？点此手动选择</text>
    </view>
  </view>

  <!-- 手动查询按钮 -->
  <button class="manual-btn" bindtap="showAllFoodsList">手动查询食物热量</button>

  <!-- 食物选择列表（识别失败兜底） -->
  <view class="foodlist-overlay" wx:if="{{showFoodList}}" bindtap="hideFoodList">
    <view class="foodlist-panel" catchtap="nop">
      <view class="foodlist-header">
        <text class="foodlist-title">选择食物</text>
        <text class="foodlist-close" bindtap="hideFoodList">✕</text>
      </view>
      <view class="foodlist-search">
        <input
          placeholder="搜索食物名称..."
          value="{{foodSearchKeyword}}"
          bindinput="filterFoodList"
          class="foodlist-search-input"
        ></input>
      </view>
      <scroll-view class="foodlist-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          class="foodlist-item"
          wx:for="{{filteredFoods}}"
          wx:key="name"
          data-index="{{index}}"
          bindtap="selectFood"
        >
          <text class="foodlist-item-name">{{item.name}}</text>
          <text class="foodlist-item-cal">{{item.calorie}} kcal/100g</text>
        </view>
        <view class="foodlist-empty" wx:if="{{filteredFoods.length === 0}}">
          <text class="foodlist-empty-text">没有匹配的食物</text>
          <button class="foodlist-empty-btn" bindtap="goAddFood">自行添加食物热量</button>
        </view>
      </scroll-view>
    </view>
  </view>
</view>